AI_PROVIDER=openai
OPENAI_API_KEY=TU_API_KEY
OPENAI_MODEL=gpt-4o
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_MAX_OUTPUT_TOKENS=700
OPENAI_TTS_ENABLED=true
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=marin
OPENAI_TTS_RESPONSE_FORMAT=mp3
AI_TEMPERATURE=0.45
AI_RESPONSE_STYLE=natural, claro, cercano y con criterio tecnico
LOCAL_AI_MODEL=qwen2:7b-instruct-q4_0
CORS_ALLOW_ORIGINS=https://afcrseguridad.com,https://www.afcrseguridad.com,http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,http://localhost:3002,http://127.0.0.1:3002
PUBLIC_API_URL=https://api.afcrseguridad.com
# La publishable se puede exponer. La Secret key queda solo en FastAPI:
# permite que el backend invoque RPC del ESP32; nunca la envies al frontend.
SUPABASE_URL=https://omkbowrspgbuwpifksfk.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_ATKf-AGUu2fsz7w-W6G2PQ_DxSb5cdE
SUPABASE_SECRET_KEY=REEMPLAZAR_CON_SECRET_KEY_PRIVADA
# Compatibilidad temporal solamente si aun usa la llave legacy:
# SUPABASE_SERVICE_ROLE_KEY=REEMPLAZAR_CON_SERVICE_ROLE_LEGACY
SUPABASE_AUDIO_BUCKET=voice-audio
VOICE_AUDIO_RETENTION_DAYS=30
# SQLite queda como fallback de pruebas si Supabase no esta configurado.
DEVICES_DB_PATH=/home/abraham/proy_ia_security/backend/devices.db
PAIRING_TOKEN_MINUTES=60
DEVICE_ONLINE_WINDOW_SECONDS=120
DEVICE_COMMAND_TTL_SECONDS=300
MQTT_SERVER=127.0.0.1
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TLS=false
MQTT_TOPIC_LUCES=casa/esp32/luces
MQTT_DEVICE_TOPIC_PREFIX=afcr/devices
